# =============================================================================
# AI Lead Manager — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_manager

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# AI: API keys are managed via admin panel (Settings page), not here.

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Telegram
TELEGRAM_BOT_TOKEN=xxx:yyy

# App
APP_NAME=AI Lead Manager
VITE_APP_URL=https://ai-lead-manager.alteran.tech
PORT=80
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# Integrations (optional)
CRM_WEBHOOK_URL=
GOOGLE_SHEETS_CREDENTIALS=
